on key {
    mode == normal {
        q -> Quit();
        Escape -> Quit();
        Space -> SetMode(space);
        : -> OpenCommandPalette();
        i -> SetMode(insert);
        C -> AddSelectionBelow();
        h -> MoveLeft();
        j -> MoveDown();
        k -> MoveUp();
        l -> MoveRight();
        w -> MoveNextWordStart();
        e -> MoveNextWordEnd();
        b -> MovePrevWordStart();
    }
    mode == insert {
        Escape -> SetMode(normal);
        Enter -> ClaudeSubmit();
    }
    mode == space {
        Escape -> SetMode(normal);
        q -> Quit();
        s -> SetMode(space_split);
        t -> [OpenRun(), SetMode(run)];
        c -> SetMode(claude);
        h -> [FocusLeft(), SetMode(normal)];
        j -> [FocusDown(), SetMode(normal)];
        k -> [FocusUp(), SetMode(normal)];
        l -> [FocusRight(), SetMode(normal)];
        : -> OpenCommandPalette();
    }
    mode == run {
        Escape -> SetMode(normal);
        Enter -> RunSubmit();
    }
    mode == space_split {
        Escape -> SetMode(normal);
        r -> [SplitRight(), SetMode(normal)];
        d -> [SplitDown(), SetMode(normal)];
        c -> [ClosePane(), SetMode(normal)];
        : -> OpenCommandPalette();
    }
    mode == claude {
        Escape -> SetMode(normal);
        c -> [OpenClaude(), SetMode(normal)];
        p -> [ClaudeToPane(), SetMode(normal)];
        l -> [ClaudeToDockLeft(), SetMode(normal)];
        r -> [ClaudeToDockRight(), SetMode(normal)];
    }
}
