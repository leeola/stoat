theme default_dark {
    let accent  = cyan;
    let primary = blue;
    let success = green;
    let warning = yellow;
    let danger  = red;
    let info    = cyan;
    let special = magenta;
    let muted   = dark_gray;
    let dim     = gray;
    let text    = white;

    ui.cursor = { modifiers: [reversed] };
    ui.cursor.input = { fg: black, bg: text };
    ui.selection = { fg: black, bg: accent };
    ui.selection.editor = { bg: muted };
    ui.selection.reversed = { fg: black, bg: text, modifiers: [reversed] };

    ui.border.focused.fg = accent;
    ui.border.inactive.fg = muted;

    ui.modal.help.fg = accent;
    ui.modal.hints.fg = warning;
    ui.modal.palette.fg = special;
    ui.modal.picker.fg = special;
    ui.modal.run.fg = warning;

    ui.prompt.fg = warning;
    ui.key_label.fg = accent;
    ui.heading = { fg: warning, modifiers: [bold] };
    ui.error.fg = danger;
    ui.text.fg = text;
    ui.text.muted.fg = muted;
    ui.text.dim.fg = dim;

    ui.badge.active.fg = warning;
    ui.badge.complete.fg = success;
    ui.badge.error.fg = danger;

    ui.statusbar.focused   = { fg: text, bg: muted };
    ui.statusbar.unfocused = { fg: muted, bg: black };
    ui.mode_label          = { fg: black, modifiers: [bold] };

    ui.statusline.normal.fg   = primary;
    ui.statusline.insert.fg   = success;
    ui.statusline.prompt.fg   = success;
    ui.statusline.run.fg      = special;
    ui.statusline.commits.fg  = warning;
    ui.statusline.rebase.fg   = danger;
    ui.statusline.reword.fg   = danger;
    ui.statusline.conflict.fg = light_red;
    ui.statusline.review.fg   = info;
    ui.statusline.default.fg  = dim;

    diff.added.fg        = success;
    diff.deleted.fg      = danger;
    diff.modified.fg     = warning;
    diff.moved.fg        = info;
    diff.context.fg      = muted;
    diff.current_hunk    = { fg: info, modifiers: [bold] };

    vcs.conflict.header  = { fg: danger, modifiers: [bold] };
    vcs.conflict.ours.fg   = success;
    vcs.conflict.theirs.fg = special;

    vcs.commit.sha.fg      = warning;
    vcs.commit.summary.fg  = text;
    vcs.commit.metadata.fg = muted;

    vcs.rebase.pick.fg   = success;
    vcs.rebase.squash.fg = warning;
    vcs.rebase.fixup.fg  = warning;
    vcs.rebase.reword.fg = special;
    vcs.rebase.edit.fg   = special;
    vcs.rebase.drop.fg   = danger;

    syntax.keyword                = { fg: primary, modifiers: [bold] };
    syntax.string.fg              = success;
    syntax.string.escape          = { fg: light_green, modifiers: [bold] };
    syntax.comment                = { fg: muted, modifiers: [italic] };
    syntax.comment.documentation  = { fg: dim, modifiers: [italic] };
    syntax.function.fg            = warning;
    syntax.function.special       = { fg: light_yellow, modifiers: [bold] };
    syntax.type.fg                = info;
    syntax.constant.fg            = special;
    syntax.operator.fg            = light_cyan;
    syntax.punctuation.fg         = dim;
    syntax.property.fg            = light_blue;
    syntax.attribute.fg           = light_magenta;
    syntax.variable.fg            = text;
    syntax.variable.special       = { fg: light_red, modifiers: [italic] };
    syntax.special.lifetime       = { fg: light_yellow, modifiers: [italic] };
    syntax.markup.title           = { fg: light_cyan, modifiers: [bold] };
    syntax.markup.link_text.fg    = light_blue;
    syntax.markup.link_uri        = { fg: primary, modifiers: [underlined] };
    syntax.markup.emphasis        = { modifiers: [italic] };
    syntax.markup.emphasis.strong = { modifiers: [bold] };
    syntax.markup.text.literal.fg = light_yellow;
    syntax.markup.strikethrough   = { modifiers: [strikethrough] };

    chat.user.fg         = success;
    chat.text.fg         = text;
    chat.meta.fg         = muted;
    chat.time.fg         = dim;
    chat.thinking        = { fg: muted, modifiers: [italic] };
    chat.tool.header.fg  = primary;
    chat.tool.body.fg    = muted;
    chat.error.fg        = danger;
    chat.separator.fg    = muted;
    chat.throbber        = { fg: special, modifiers: [bold] };
}

on init {
    theme = default_dark;
}

on key {
    ? -> OpenHelp();
    mode == normal && help_open {
        Escape -> CloseHelp();
        i -> SetMode(prompt);
        a -> SetMode(prompt);
        Enter -> SubmitPromptInput();
        j -> HelpSelectNext();
        k -> HelpSelectPrev();
        Up -> HelpSelectPrev();
        Down -> HelpSelectNext();
        g -> HelpJumpFirst();
        G -> HelpJumpLast();
        Ctrl-u -> HelpScrollDetailUp();
        Ctrl-d -> HelpScrollDetailDown();
        PageUp -> HelpScrollDetailUp();
        PageDown -> HelpScrollDetailDown();
        BackTab -> HelpScopeToggle();
    }
    mode == normal {
        q -> Quit();
        Space -> SetMode(space);
        : -> OpenCommandPalette();
        i -> SetMode(insert);
        C -> AddSelectionBelow();
        Alt-C -> AddSelectionAbove();
        h -> MoveLeft();
        j -> MoveDown();
        k -> MoveUp();
        l -> MoveRight();
        Ctrl-b -> PageUp();
        Ctrl-f -> PageDown();
        Ctrl-u -> HalfPageUp();
        Ctrl-d -> HalfPageDown();
        w -> MoveNextWordStart();
        e -> MoveNextWordEnd();
        b -> MovePrevWordStart();
        H -> ExtendLeft();
        J -> ExtendDown();
        K -> ExtendUp();
        L -> ExtendRight();
        B -> ExtendPrevWordStart();
        W -> ExtendNextWordStart();
        E -> ExtendNextWordEnd();
        Home -> GotoLineStart();
        End -> GotoLineEnd();
        ; -> CollapseSelection();
        Alt-; -> FlipSelections();
        Alt-s -> SplitSelectionOnNewline();
        Alt-o -> ExpandSelection();
        Alt-Up -> ExpandSelection();
        Alt-i -> ShrinkSelection();
        Alt-Down -> ShrinkSelection();
        & -> AlignSelections();
        % -> SelectAll();
        x -> SelectLineBelow();
        , -> KeepPrimarySelection();
        ( -> RotateSelectionsBackward();
        ) -> RotateSelectionsForward();
        _ -> TrimSelections();
        ~ -> SwitchCase();
        ` -> SwitchToLowercase();
        Alt-` -> SwitchToUppercase();
        Ctrl-a -> Increment();
        Ctrl-x -> Decrement();
        d -> DeleteSelection();
        u -> Undo();
        U -> Redo();
        > -> IndentSelection();
        < -> UnindentSelection();
        g -> SetMode(goto);
        z -> SetMode(z);
        ] -> SetMode(bracket_next);
        [ -> SetMode(bracket_prev);
        R -> OpenReview();
    }
    mode == goto {
        Escape -> SetMode(normal);
        i -> [GotoFirstNonwhitespace(), SetMode(normal)];
        j -> [GotoLastLine(), SetMode(normal)];
        k -> [GotoFileStart(), SetMode(normal)];
        t -> [GotoWindowTop(), SetMode(normal)];
        c -> [GotoWindowCenter(), SetMode(normal)];
        b -> [GotoWindowBottom(), SetMode(normal)];
        : -> OpenCommandPalette();
    }
    mode == z {
        Escape -> SetMode(normal);
        z -> [AlignViewCenter(), SetMode(normal)];
        t -> [AlignViewTop(), SetMode(normal)];
        b -> [AlignViewBottom(), SetMode(normal)];
        j -> [ScrollDown(), SetMode(normal)];
        k -> [ScrollUp(), SetMode(normal)];
        : -> OpenCommandPalette();
    }
    mode == bracket_next {
        Escape -> SetMode(normal);
        g -> [GotoNextChange(), SetMode(normal)];
        : -> OpenCommandPalette();
    }
    mode == bracket_prev {
        Escape -> SetMode(normal);
        g -> [GotoPrevChange(), SetMode(normal)];
        : -> OpenCommandPalette();
    }
    mode == commits {
        Escape -> CloseCommits();
        q -> CloseCommits();
        j -> CommitsNext();
        n -> CommitsNext();
        k -> CommitsPrev();
        p -> CommitsPrev();
        g -> CommitsFirst();
        G -> CommitsLast();
        r -> CommitsRefresh();
        o -> CommitsOpenReview();
        Enter -> CommitsOpenReview();
        i -> EnterRebase();
        : -> OpenCommandPalette();
    }
    mode == rebase {
        Escape -> AbortRebase();
        q -> AbortRebase();
        j -> RebaseNext();
        k -> RebasePrev();
        K -> RebaseMoveUp();
        J -> RebaseMoveDown();
        p -> SetRebaseOpPick();
        s -> SetRebaseOpSquash();
        f -> SetRebaseOpFixup();
        d -> SetRebaseOpDrop();
        r -> SetRebaseOpReword();
        e -> SetRebaseOpEdit();
        Enter -> ExecuteRebase();
        : -> OpenCommandPalette();
    }
    mode == reword {
        Escape -> RewordAbort();
        Ctrl-s -> RewordConfirm();
        i -> SetMode(reword_insert);
        a -> SetMode(reword_insert);
        h -> MoveLeft();
        j -> MoveDown();
        k -> MoveUp();
        l -> MoveRight();
        w -> MoveNextWordStart();
        e -> MoveNextWordEnd();
        b -> MovePrevWordStart();
        : -> OpenCommandPalette();
    }
    mode == reword_insert {
        Escape -> SetMode(reword);
        Ctrl-s -> RewordConfirm();
    }
    mode == conflict {
        Escape -> ConflictAbort();
        a -> ConflictAbort();
        j -> ConflictNextFile();
        k -> ConflictPrevFile();
        o -> ConflictTakeOurs();
        t -> ConflictTakeTheirs();
        s -> ConflictSkipEntry();
        Enter -> ConflictApply();
        : -> OpenCommandPalette();
    }
    mode == review {
        Escape -> CloseReview();
        q -> CloseReview();
        n -> ReviewNextChunk();
        p -> ReviewPrevChunk();
        j -> ReviewNextChunk();
        k -> ReviewPrevChunk();
        s -> ReviewStageChunk();
        u -> ReviewUnstageChunk();
        Space -> ReviewToggleStage();
        S -> ReviewSkipChunk();
        A -> ReviewApplyStaged();
        D -> ReviewRemoveSelected();
        C -> RebaseContinue();
        r -> ReviewRefresh();
        : -> OpenCommandPalette();
    }
    mode == insert {
        Escape -> SetMode(normal);
        Enter -> ClaudeSubmit();
    }
    mode == prompt && finder_open {
        Up -> FileFinderSelectPrev();
        Down -> FileFinderSelectNext();
        Ctrl-p -> FileFinderSelectPrev();
        Ctrl-n -> FileFinderSelectNext();
        BackTab -> FileFinderScopeToggle();
    }
    mode == prompt && palette_open {
        Up -> PaletteSelectPrev();
        Down -> PaletteSelectNext();
        Ctrl-p -> PaletteSelectPrev();
        Ctrl-n -> PaletteSelectNext();
        BackTab -> PaletteScopeToggle();
    }
    mode == prompt && help_open {
        Up -> HelpSelectPrev();
        Down -> HelpSelectNext();
        Ctrl-p -> HelpSelectPrev();
        Ctrl-n -> HelpSelectNext();
        Ctrl-u -> HelpScrollDetailUp();
        Ctrl-d -> HelpScrollDetailDown();
        PageUp -> HelpScrollDetailUp();
        PageDown -> HelpScrollDetailDown();
        BackTab -> HelpScopeToggle();
    }
    mode == prompt {
        Escape -> CancelPromptInput();
        Enter -> SubmitPromptInput();
        Shift-Enter -> PromptInsertNewline();
        Alt-Enter -> PromptInsertNewline();
        Up -> MoveUp();
        Down -> MoveDown();
    }
    mode == space {
        Escape -> SetMode(normal);
        q -> Quit();
        a -> SetMode(space_pane_nav);
        t -> [OpenRun(), SetMode(run)];
        c -> SetMode(claude);
        w -> SetMode(space_workspace);
        p -> OpenFileFinder();
        : -> OpenCommandPalette();
    }
    mode == space_workspace {
        Escape -> SetMode(normal);
        n -> [NewWorkspace(), SetMode(normal)];
        c -> [CopyWorkspace(), SetMode(normal)];
        s -> [SwitchWorkspace(), SetMode(normal)];
        x -> [CloseWorkspace(), SetMode(normal)];
        : -> OpenCommandPalette();
    }
    mode == run {
        Escape -> SetMode(normal);
        Enter -> RunSubmit();
        Up -> RunHistoryPrev();
        Down -> RunHistoryNext();
    }
    mode == space_pane_nav {
        Escape -> SetMode(normal);
        s -> [SplitRight(), SetMode(normal)];
        v -> [SplitDown(), SetMode(normal)];
        n -> SetMode(space_pane_nav_new);
        f -> OpenFileFinderHSplit();
        F -> OpenFileFinderVSplit();
        q -> [ClosePane(), SetMode(normal)];
        o -> [CloseOtherPanes(), SetMode(normal)];
        w -> [FocusNext(), SetMode(normal)];
        h -> [FocusLeft(), SetMode(normal)];
        Left -> [FocusLeft(), SetMode(normal)];
        j -> [FocusDown(), SetMode(normal)];
        Down -> [FocusDown(), SetMode(normal)];
        k -> [FocusUp(), SetMode(normal)];
        Up -> [FocusUp(), SetMode(normal)];
        l -> [FocusRight(), SetMode(normal)];
        Right -> [FocusRight(), SetMode(normal)];
        : -> OpenCommandPalette();
    }
    mode == space_pane_nav_new {
        Escape -> SetMode(normal);
        s -> [SplitNewRight(), SetMode(normal)];
        v -> [SplitNewDown(), SetMode(normal)];
        : -> OpenCommandPalette();
    }
    mode == claude {
        Escape -> SetMode(normal);
        c -> [OpenClaude(), SetMode(normal)];
        p -> [ClaudeToPane(), SetMode(normal)];
        l -> [ClaudeToDockLeft(), SetMode(normal)];
        r -> [ClaudeToDockRight(), SetMode(normal)];
        f -> [ClaudeToggleFollow(), SetMode(normal)];
    }
}
