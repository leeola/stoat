# Stoat Editor Default Keymap Configuration
#
# Key syntax: single chars are literal (h, G, 0, $, :), multi-char are named (Space, Enter, Escape).
# Modifiers use dash separator: ctrl-s, shift-tab.

on key {
    # TextEditor Context
    focus == "TextEditor" {
        # Global bindings (all modes)
        ctrl-c -> Copy();
        ctrl-x -> Cut();
        ctrl-v -> Paste();
        ctrl-q -> Quit();
        ctrl-o -> Open();
        Tab -> Indent();
        shift-Tab -> Outdent();

        # Normal Mode
        mode == "normal" {
            # Navigation
            h -> MoveLeft();
            j -> MoveDown();
            k -> MoveUp();
            l -> MoveRight();
            w -> MoveNextWordStart();
            b -> MovePrevWordStart();
            W -> MoveNextLongWordStart();
            B -> MovePrevLongWordStart();
            e -> MoveNextWordEnd();
            E -> MoveNextLongWordEnd();
            0 -> MoveToLineStart();
            $ -> MoveToLineEnd();
            G -> MoveToFileEnd();
            g -> SetMode(goto);
            ctrl-b -> PageUp();
            ctrl-f -> PageDown();
            ctrl-u -> HalfPageUp();
            ctrl-d -> HalfPageDown();
            pageup -> PageUp();
            pagedown -> PageDown();

            # Find-char
            f -> FindCharForward();
            F -> FindCharBackward();
            t -> TillCharForward();
            T -> TillCharBackward();

            # Mode transitions
            i -> SetMode(insert);
            v -> SetMode(visual);
            space -> SetMode(space);

            # Editing
            x -> SelectLine();
            X -> DeleteLeft();
            d -> DeleteSelection();
            c -> ChangeSelection();
            D -> DeleteToEndOfLine();
            o -> OpenLineBelow();
            O -> OpenLineAbove();
            a -> Append();
            A -> AppendAtLineEnd();
            I -> InsertAtLineStart();
            H -> SelectLeft();
            J -> SelectDown();
            K -> SelectUp();
            L -> SelectRight();
            alt-j -> JoinLines();
            p -> PasteAfter();
            P -> PasteBefore();
            r -> ReplaceChar();
            ` -> Lowercase();
            ~ -> SwapCase();
            alt-` -> Uppercase();
            > -> Indent();
            < -> Outdent();

            # Selection manipulation
            ; -> CollapseSelection();
            , -> KeepPrimarySelection();
            alt-; -> FlipSelection();
            % -> SelectAll();
            s -> SelectRegex();
            C -> AddSelectionBelow();

            # Undo/Redo
            u -> Undo();
            ctrl-r -> Redo();

            # File operations
            ctrl-s -> Save();

            # Multi-cursor
            ctrl-shift-l -> SplitSelectionIntoLines();
            ctrl-shift-d -> SelectPrevious();
            ctrl-shift-g -> SelectAllMatches();
            ctrl-alt-up -> AddSelectionAbove();
            ctrl-alt-down -> AddSelectionBelow();

            # Command palette
            : -> OpenCommandPalette();
            ctrl-; -> OpenCommandPaletteV2();

            # View mode
            z -> SetMode(view);

            # Help
            ? -> OpenHelpOverlay();
        }

        # Insert Mode
        mode == "insert" {
            escape -> SetMode(normal);

            # Navigation
            left -> MoveLeft();
            right -> MoveRight();
            up -> MoveUp();
            down -> MoveDown();
            alt-left -> MoveWordLeft();
            alt-right -> MoveWordRight();
            ctrl-a -> MoveToLineStart();
            ctrl-e -> MoveToLineEnd();

            # Deletion
            backspace -> DeleteLeft();
            delete -> DeleteRight();
            alt-backspace -> DeleteWordLeft();
            alt-delete -> DeleteWordRight();

            # Editing
            enter -> NewLine();

            # File operations
            ctrl-s -> Save();

            # Undo/Redo
            ctrl-z -> Undo();
            ctrl-shift-z -> Redo();
        }

        # Visual Mode
        mode == "visual" {
            escape -> SetMode(normal);

            # Selection movement
            h -> SelectLeft();
            j -> SelectDown();
            k -> SelectUp();
            l -> SelectRight();
            left -> SelectLeft();
            right -> SelectRight();
            up -> SelectUp();
            down -> SelectDown();
            w -> MoveNextWordStart();
            b -> MovePrevWordStart();
            W -> MoveNextLongWordStart();
            B -> MovePrevLongWordStart();
            e -> ExtendNextWordEnd();
            E -> ExtendNextLongWordEnd();
            0 -> SelectToLineStart();
            $ -> SelectToLineEnd();

            # Operations on selection
            y -> Yank();
            d -> DeleteSelection();
            x -> DeleteSelection();
            c -> ChangeSelection();
            > -> Indent();
            < -> Outdent();
            ` -> Lowercase();
            ~ -> SwapCase();

            # Selection manipulation
            ; -> CollapseSelection();
            , -> KeepPrimarySelection();
            alt-; -> FlipSelection();

            # Multi-cursor
            ctrl-shift-l -> SplitSelectionIntoLines();
            ctrl-d -> SelectNext();
            ctrl-shift-d -> SelectPrevious();
            ctrl-shift-g -> SelectAllMatches();
            ctrl-alt-up -> AddSelectionAbove();
            ctrl-alt-down -> AddSelectionBelow();
        }

        # Goto Mode (transient - auto-reverts to normal after action)
        mode == "goto" {
            escape -> SetMode(normal);
            g -> MoveToFileStart();
            e -> MoveToFileEnd();
            h -> MoveToLineStart();
            l -> MoveToLineEnd();
            s -> MoveToFirstNonWhitespace();
            i -> MoveToFirstNonWhitespace();
            j -> MoveToFileEnd();
            k -> MoveToFileStart();
        }

        # Buffer Mode (transient - auto-reverts to normal after action)
        mode == "buffer" {
            escape -> SetMode(normal);
            b -> OpenBufferFinder();
            d -> CloseBuffer();
        }

        # LSP Mode (transient - auto-reverts to normal after action)
        mode == "lsp" {
            escape -> SetMode(normal);
            w -> GotoNextDiagnostic();
            W -> GotoPrevDiagnostic();
            i -> LspHover();
            a -> LspCodeAction();
            r -> LspRenameSymbol();
            j -> LspGotoDefinition();
            k -> LspGotoTypeDefinition();
            t -> LspGotoImplementation();
            s -> LspSymbolPicker();
            S -> LspWorkspaceSymbolPicker();
        }

        # View Mode (transient - auto-reverts to normal after action)
        mode == "view" {
            escape -> SetMode(normal);
            z -> CenterScreen();
        }

    }

    # Pane Mode (global - works from any focus context)
    mode == "pane" {
        escape -> SetMode(normal);

        # Splitting
        v -> SplitDown();
        s -> SplitRight();
        ctrl-v -> SplitRight();
        ctrl-s -> SplitDown();

        # Close
        q -> ClosePane();
        o -> CloseOtherPanes();

        # Focus navigation
        h -> FocusPaneLeft();
        j -> FocusPaneDown();
        k -> FocusPaneUp();
        l -> FocusPaneRight();
        left -> FocusPaneLeft();
        down -> FocusPaneDown();
        up -> FocusPaneUp();
        right -> FocusPaneRight();
        ctrl-h -> FocusPaneLeft();
        ctrl-j -> FocusPaneDown();
        ctrl-k -> FocusPaneUp();
        ctrl-l -> FocusPaneRight();
    }

    # Space Mode (global - works from any focus context)
    mode == "space" {
        escape -> SetMode(normal);
        a -> SetMode(pane);
        p -> OpenFileFinder();
        b -> SetMode(buffer);
        g -> SetMode(git);
        d -> ToggleDiffHunk();
        l -> SetMode(lsp);
        o -> OpenClaudeChat();
    }

    # Git Mode (transient - auto-reverts to normal after action)
    mode == "git" {
        escape -> SetMode(normal);
        s -> OpenGitStatus();
        b -> OpenGitBlame();
        d -> OpenDiffReview();
        r -> OpenRebase();
        l -> OpenGitLog();
        x -> OpenConflictReview();
    }

    # Git Log Context
    focus == "GitLog" {
        mode == "git_log" {
            escape -> GitLogDismiss();
            q -> GitLogDismiss();
            j -> GitLogNext();
            k -> GitLogPrev();
            down -> GitLogNext();
            up -> GitLogPrev();
            enter -> GitLogSelect();
            l -> GitLogDetailNextFile();
            h -> GitLogDetailPrevFile();
            / -> GitLogSearchOpen();
            ctrl-f -> GitLogPageDown();
            ctrl-b -> GitLogPageUp();
        }
    }

    # Claude Context
    focus == "Claude" {
        mode == "normal" {
            i -> SetMode(insert);
            space -> SetMode(space);
            q -> ClosePane();
            : -> OpenCommandPalette();
            ? -> OpenHelpOverlay();
            ctrl-q -> Quit();
            Tab -> CycleClaudePermission();
        }
        mode == "insert" {
            escape -> SetMode(normal);
        }
    }

    # FileFinder Context
    focus == "FileFinder" {
        escape -> SetKeyContext(TextEditor);
        up -> FileFinderPrev();
        down -> FileFinderNext();
        ctrl-p -> FileFinderPrev();
        ctrl-n -> FileFinderNext();
        backspace -> DeleteLeft();
        enter -> FileFinderSelect();
    }

    # BufferFinder Context
    focus == "BufferFinder" {
        escape -> SetKeyContext(TextEditor);
        up -> BufferFinderPrev();
        down -> BufferFinderNext();
        ctrl-p -> BufferFinderPrev();
        ctrl-n -> BufferFinderNext();
        backspace -> DeleteLeft();
        enter -> BufferFinderSelect();
    }

    # SymbolPicker Context
    focus == "SymbolPicker" {
        escape -> SymbolPickerDismiss();
        up -> SymbolPickerPrev();
        down -> SymbolPickerNext();
        ctrl-p -> SymbolPickerPrev();
        ctrl-n -> SymbolPickerNext();
        backspace -> DeleteLeft();
        enter -> SymbolPickerSelect();
    }

    # CommandPalette Context
    focus == "CommandPalette" {
        escape -> SetKeyContext(TextEditor);
        up -> CommandPalettePrev();
        down -> CommandPaletteNext();
        ctrl-p -> CommandPalettePrev();
        ctrl-n -> CommandPaletteNext();
        enter -> CommandPaletteExecute();
        backspace -> DeleteLeft();
        ctrl-h -> ToggleCommandPaletteHidden();
    }

    # CommandPaletteV2 Context
    focus == "CommandPaletteV2" {
        escape -> DismissCommandPaletteV2();
        up -> SelectPrevCommandV2();
        down -> SelectNextCommandV2();
        ctrl-p -> SelectPrevCommandV2();
        ctrl-n -> SelectNextCommandV2();
        enter -> AcceptCommandPaletteV2();
        backspace -> DeleteLeft();
    }

    # Git Context
    focus == "Git" {
        mode == "git_status" {
            escape -> SetKeyContext(TextEditor);
            j -> GitStatusNext();
            k -> GitStatusPrev();
            down -> GitStatusNext();
            up -> GitStatusPrev();
            ctrl-n -> GitStatusNext();
            ctrl-p -> GitStatusPrev();
            enter -> GitStatusSelect();
            f -> SetMode(git_filter);
        }

        mode == "git_filter" {
            escape -> SetMode(git_status);
            a -> GitStatusSetFilterAll();
            s -> GitStatusSetFilterStaged();
            u -> GitStatusSetFilterUnstaged();
            w -> GitStatusSetFilterUnstagedWithUntracked();
            t -> GitStatusSetFilterUntracked();
        }
    }

    # DiffReview Context
    focus == "DiffReview" {
        mode == "diff_review" {
            escape -> SetKeyContext(TextEditor);
            j -> DiffReviewNextHunk();
            k -> DiffReviewPrevHunk();
            down -> DiffReviewNextHunk();
            up -> DiffReviewPrevHunk();
            ctrl-n -> DiffReviewNextHunk();
            ctrl-p -> DiffReviewPrevHunk();
            space -> DiffReviewApproveHunk();
            a -> DiffReviewApproveHunk();
            enter -> DiffReviewApproveHunk();
            t -> DiffReviewToggleApproval();
            n -> DiffReviewNextUnreviewedHunk();
            R -> DiffReviewResetProgress();
            ? -> OpenHelpOverlay();
            q -> DiffReviewDismiss();
            c -> DiffReviewCycleComparisonMode();
            s -> GitToggleStageHunk();
            S -> GitToggleStageLine();
            u -> GitUnstageHunk();
            r -> DiffReviewRevertHunk();
            f -> DiffReviewToggleFollow();
            J -> MoveDown();
            K -> MoveUp();
        }
    }

    # ConflictReview Context
    focus == "ConflictReview" {
        mode == "conflict_review" {
            escape -> SetKeyContext(TextEditor);
            o -> ConflictAcceptOurs();
            t -> ConflictAcceptTheirs();
            b -> ConflictAcceptBoth();
            j -> ConflictNextConflict();
            k -> ConflictPrevConflict();
            down -> ConflictNextConflict();
            up -> ConflictPrevConflict();
            q -> ConflictReviewDismiss();
            v -> ConflictToggleView();
            ? -> OpenHelpOverlay();
        }
    }

    # BlameReview Context
    focus == "BlameReview" {
        mode == "blame_review" {
            escape -> BlameDismiss();
            j -> MoveDown();
            k -> MoveUp();
            h -> MoveLeft();
            l -> MoveRight();
            G -> MoveToFileEnd();
            ctrl-d -> HalfPageDown();
            ctrl-u -> HalfPageUp();
            ctrl-f -> FullPageDown();
            ctrl-b -> FullPageUp();
            a -> BlameToggleAuthor();
            d -> BlameToggleDate();
            i -> BlameOpenCommitDiff();
            q -> BlameDismiss();
            ? -> OpenHelpOverlay();
        }
    }

    # Rebase Context
    focus == "Rebase" {
        mode == "rebase_plan" {
            escape -> RebaseDismiss();
            j -> RebaseNext();
            k -> RebasePrev();
            down -> RebaseNext();
            up -> RebasePrev();
            ctrl-n -> RebaseNext();
            ctrl-p -> RebasePrev();
            J -> RebaseMoveDown();
            K -> RebaseMoveUp();
            p -> RebaseSetPick();
            s -> RebaseSetSquash();
            f -> RebaseSetFixup();
            e -> RebaseSetEdit();
            d -> RebaseSetDrop();
            w -> RebaseSetReword();
            enter -> RebaseConfirm();
            ? -> OpenHelpOverlay();
        }
        mode == "rebase_progress" {
            escape -> RebaseDismiss();
            c -> RebaseContinue();
            a -> RebaseAbort();
            s -> RebaseSkip();
            m -> RebaseEditMessage();
            ? -> OpenHelpOverlay();
        }
    }

    # BlameCommitDiff Context
    focus == "BlameCommitDiff" {
        mode == "blame_commit_diff" {
            j -> BlameCommitDiffNext();
            k -> BlameCommitDiffPrev();
            q -> BlameCommitDiffDismiss();
            escape -> BlameCommitDiffDismiss();
        }
    }

    # HelpModal Context
    focus == "HelpModal" {
        escape -> SetKeyContext(TextEditor);
    }

    # AboutModal Context
    focus == "AboutModal" {
        escape -> SetKeyContext(TextEditor);
    }
}
