+/// A greeter that holds a name.
+pub struct Greeter {
+    name: String,
+}
+
+impl Greeter {
+    /// Create a new greeter for the given name.
+    pub fn new(name: &str) -> Self {
+        Self {
+            name: name.to_string(),
+        }
+    }
+
+    /// Return a greeting message.
+    pub fn greet(&self) -> String {
+        format!("Hello, {}!", self.name)
+    }
+}
+
+fn main() {
+    let g = Greeter::new("world");
+    let msg = g.greet();
+    println!("{msg}");
+}
